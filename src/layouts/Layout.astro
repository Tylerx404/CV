---
import "@/styles/global.css";
import { withBase } from "@/lib/urls";

interface Props {
	title: string;
	description: string;
	image: string;
	url: string;
	theme: string;
	lang: "en" | "vi";
}

const { title, description, image, url, theme, lang } = Astro.props;
const resolvedUrl = new URL(url, Astro.site ?? Astro.url).toString();
const resolvedImage = new URL(image, Astro.site ?? Astro.url).toString();
---

<!doctype html>
<html lang={lang}>
	<head>
		<script is:inline>
			const savedLocale = localStorage.getItem("locale") === "vi" ? "vi" : "en";
			const validRoles = ["fullstack", "frontend", "backend"];
			const savedRole = localStorage.getItem("role");
			document.documentElement.setAttribute("lang", savedLocale);
			document.documentElement.setAttribute("data-locale", savedLocale);
			document.documentElement.setAttribute("data-role", validRoles.includes(savedRole || "") ? savedRole || "fullstack" : "fullstack");
		</script>
		<meta charset="UTF-8" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={withBase("/favicon.svg")} />
		<link rel="preload" as="image" href={image} />

		<meta property="og:url" content={resolvedUrl} />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={resolvedImage} />

		<meta name="twitter:card" content="summary_large_image" />
		<meta property="twitter:domain" content={new URL(resolvedUrl).hostname} />
		<meta property="twitter:url" content={resolvedUrl} />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={resolvedImage} />

		<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Itim" />
	</head>
	<body data-theme={theme} class="relative bg-skin-fill">
		<div class="absolute top-0 -z-10 h-full w-full print:hidden">
			<div class="bg-skin-hue/10 absolute bottom-auto left-[20%] right-auto top-0 h-[200px] w-[200px] -translate-x-[30%] translate-y-[20%] rounded-full blur-[80px] invert-0 dark:bg-white/5"></div>
		</div>
		<slot />
		<style is:global>
			body,
			figure {
				margin: 0;
				padding: 0;
			}

			a {
				text-decoration: none;
			}

			ul {
				list-style: none;
				margin: 0;
				padding: 0;
			}

			*,
			*::before,
			*::after {
				box-sizing: border-box;
			}

			h1,
			h2,
			h3,
			h4 {
				color: var(--color-text-base);
				margin: 0;
				font-family:
					system-ui,
					-apple-system,
					BlinkMacSystemFont,
					"Segoe UI",
					Roboto,
					Oxygen,
					Ubuntu,
					Cantarell,
					"Open Sans",
					"Helvetica Neue",
					sans-serif;
			}

			p {
				font-size: 0.875rem;
				line-height: 1.25rem;
				color: var(--color-text-muted);
				line-height: 1.5;
				text-wrap: pretty;
			}

			.print {
				display: none !important;
			}

			.dev * {
				border: 1px solid rgb(239 68 68 / 0.5);
				background-color: rgb(239 68 68 / 0.05);
			}

			#hotkeypad [data-backdrop] {
				background-color: rgb(39 39 42) !important;
				opacity: 0.8 !important;
			}

			@media print {
				.no-print {
					display: none !important;
				}

				.print {
					display: block !important;
				}

				astro-dev-toolbar {
					display: none !important;
				}

				article {
					break-inside: avoid;
				}
			}
		</style>

		<script>
			import Alpine from "alpinejs";
			import collapse from "@alpinejs/collapse";

			Alpine.plugin(collapse);

			Alpine.start();
		</script>
	</body>
</html>
