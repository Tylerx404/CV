<button
	type="button"
	class="inline-flex h-8 items-center justify-center gap-1 rounded-md px-2 text-skin-base transition-colors duration-200 hover:text-skin-hue focus:outline-none active:text-skin-hue"
	data-language-switch
	data-label-en="Language"
	data-label-vi="Ngôn ngữ"
	title="Language: EN"
	aria-label="Language: EN"
>
	<svg
		xmlns="http://www.w3.org/2000/svg"
		width="18"
		height="18"
		viewBox="0 0 24 24"
		fill="none"
		stroke="currentColor"
		stroke-width="2"
		stroke-linecap="round"
		stroke-linejoin="round"
		aria-hidden="true"
	>
		<circle cx="12" cy="12" r="10"></circle>
		<path d="M2 12h20"></path>
		<path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
	</svg>
	<span class="text-xs font-medium lowercase" data-language-switch-label>en</span>
</button>

<script>
	const languageButtons = document.querySelectorAll("[data-language-switch]");
	let activeLocale = localStorage.getItem("locale") === "vi" ? "vi" : "en";

	const syncLocaleState = () => {
		document.documentElement.setAttribute("data-locale", activeLocale);
		document.documentElement.setAttribute("lang", activeLocale);
		localStorage.setItem("locale", activeLocale);

		languageButtons.forEach((button) => {
			const label = activeLocale === "vi" ? button.getAttribute("data-label-vi") : button.getAttribute("data-label-en");
			button.setAttribute("title", `${label}: ${activeLocale.toUpperCase()}`);
			button.setAttribute("aria-label", `${label}: ${activeLocale.toUpperCase()}`);

			const text = button.querySelector("[data-language-switch-label]");
			if (text) {
				text.textContent = activeLocale;
			}
		});
	};

	syncLocaleState();

	languageButtons.forEach((button) => {
		button.addEventListener("click", () => {
			activeLocale = activeLocale === "en" ? "vi" : "en";
			syncLocaleState();
			window.dispatchEvent(new CustomEvent("localechange", { detail: { locale: activeLocale } }));
		});
	});
</script>
