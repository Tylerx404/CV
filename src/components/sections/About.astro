---
import type { ResumeBasics } from "@/lib/cv";
import Section from "../Section.astro";

interface Props {
	basics: ResumeBasics;
	title: string;
}

const { basics, title } = Astro.props as Props;
const { label, summary, roleProfiles } = basics;
const profiles = roleProfiles ?? {
	fullstack: { label, summary },
	frontend: { label, summary },
	backend: { label, summary },
};
---

<Section title={title}>
	<p
		data-role-content
		data-role-fullstack={profiles.fullstack.summary}
		data-role-frontend={profiles.frontend.summary}
		data-role-backend={profiles.backend.summary}
		data-role-summary
	>
		{summary}
	</p>
</Section>
